# Copy to .env and adjust. Server loads .env from apps/server when cwd is apps/server (pnpm dev).

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_workspace

# Optional: ComfyUI HTTP API (typical default http://127.0.0.1:8188). Required for /comfyui routes.
# WSL2 + Comfy on Windows: use Windows host IP, not 127.0.0.1, unless Comfy listens inside WSL.
COMFYUI_BASE_URL=http://127.0.0.1:8188
# COMFYUI_HEALTH_TIMEOUT_MS=15000
